// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  ADMIN
  DOCTOR
  PATIENT
  CLINIC_MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum RecordType {
  CONSULTATION
  EXAM
  PRESCRIPTION
  DIAGNOSIS
}

enum AttachmentType {
  PDF
  IMAGE
  DOCUMENT
}

// User Model
model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  name          String
  role          UserRole   @default(PATIENT)
  status        UserStatus @default(PENDING_VERIFICATION)
  phone         String?
  CPF           String?    @unique
  CNPJ          String?    @unique
  CRM           String?    @unique
  COREN         String?    @unique
  avatar        String?
  refreshToken  String?
  emailVerified Boolean    @default(false)

  patientProfile   PatientProfile?
  recordsAsPatient MedicalRecord[] @relation("PatientRecords")
  recordsAsDoctor  MedicalRecord[] @relation("DoctorRecords")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model PatientProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  susCard           String?  @unique
  bloodType         String? // Ex: "A+", "O-"
  allergies         String[] // Array no Postgres
  medications       String[] // Antigos ou contínuos
  medicalConditions String[] // Doenças preexistentes (diabetes, hipertensão...)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("patient_profiles")
}

model MedicalRecord {
  id           String              @id @default(cuid())
  pacienteId   String
  paciente     User                @relation("PatientRecords", fields: [pacienteId], references: [id], onDelete: Cascade)
  doctorId     String
  doctor       User                @relation("DoctorRecords", fields: [doctorId], references: [id], onDelete: Cascade)
  type         RecordType          @default(CONSULTATION)
  title        String // Ex: "Consulta de rotina", "Tomografia do tórax"
  description  String // Descrição detalhada
  observations String? // Observações adicionais do médico
  attachments  MedicalAttachment[]
  recordDate   DateTime            @default(now()) // Data do exame/consulta
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([pacienteId])
  @@index([doctorId])
  @@map("medical_records")
}

model MedicalAttachment {
  id         String         @id @default(cuid())
  recordId   String
  record     MedicalRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fileName   String // Nome original do arquivo
  fileSize   Int // Tamanho em bytes
  filePath   String // Caminho relativo no servidor
  fileType   AttachmentType
  mimeType   String // "application/pdf", "image/png", etc
  uploadedAt DateTime       @default(now())

  @@index([recordId])
  @@map("medical_attachments")
}
